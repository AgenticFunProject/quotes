meta {
  name: Get Quote by Reference
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/quotes/reference/{{quoteReference}}
  body: none
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns quote payload", function() {
    expect(res.body.id).to.be.a("string");
    expect(res.body.quoteReference).to.equal(bruno.getEnvVar("quoteReference"));
  });
}
